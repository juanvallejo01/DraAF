# =============================================
# Docker Compose — Variables de entorno
# Copiar a .env y rellenar los valores reales
# =============================================

# MongoDB
MONGO_USER=draaf
MONGO_PASSWORD=cambia_esta_contrasena_segura

# JWT (generar con: openssl rand -hex 64)
JWT_SECRET=cambia_este_secreto_por_uno_muy_largo_y_aleatorio

# URLs
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# WhatsApp Business API — obtener en Meta Business Suite
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=draaf_webhook_token_seguro
